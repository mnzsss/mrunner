{
	"name": "@mrunner/monorepo",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "doppler run -p mrunner -c prd -- pnpm --filter @mrunner/renderer dev",
		"build": "pnpm --filter @mrunner/renderer build",
		"preview": "doppler run -p mrunner -c prd -- pnpm --filter @mrunner/renderer preview",
		"tauri": "doppler run -p mrunner -c prd -- tauri -c apps/launcher/tauri.conf.json",
		"tauri:dev": "WEBKIT_DISABLE_DMABUF_RENDERER=1 GDK_BACKEND=x11 doppler run -p mrunner -c prd -- tauri dev -c apps/launcher/tauri.conf.json",
		"tauri:build": "tauri build -c apps/launcher/tauri.conf.json",
		"lint": "biome lint .",
		"format": "biome format . --write",
		"check": "biome check . --write",
		"release": "release-it --config release/release-it.json",
		"release:patch": "release-it patch --config release/release-it.json",
		"release:minor": "release-it minor --config release/release-it.json",
		"release:major": "release-it major --config release/release-it.json",
		"release:dry-run": "release-it --dry-run --config release/release-it.json",
		"test": "cargo test -p mrunner && pnpm --filter @mrunner/renderer test",
		"test:rust": "cargo test -p mrunner",
		"test:ts": "pnpm --filter @mrunner/renderer test"
	},
	"pnpm": {
		"overrides": {
			"mermaid": "^11.15.0",
			"lodash-es": "^4.18.1",
			"dompurify": "^3.4.0",
			"uuid": "^11.1.1",
			"react-router": "^7.15.0",
			"hono": "^4.12.21",
			"@hono/node-server": "^1.19.13",
			"@modelcontextprotocol/sdk": "^1.26.0",
			"qs": "^6.15.2",
			"minimatch": "^10.2.3",
			"path-to-regexp": "^8.4.0",
			"picomatch": "^4.0.4",
			"fast-uri": "^3.1.2",
			"ajv": "^8.18.0",
			"diff": "^8.0.3",
			"postcss": "^8.5.10",
			"@isaacs/brace-expansion": "^5.0.1"
		}
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.10",
		"@release-it/conventional-changelog": "^10.0.4",
		"@tauri-apps/cli": "^2.1.0",
		"@types/node": "^25",
		"release-it": "^19.1.0",
		"typescript": "^5"
	},
	"version": "0.1.1"
}
