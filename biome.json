{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "master"
	},
	"files": {
		"includes": [
			"**",
			"!**/dist",
			"!src-tauri/gen",
			"!apps/launcher/gen",
			"!.claude"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineEnding": "lf"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"useSemanticElements": "off",
				"noLabelWithoutControl": "off"
			},
			"suspicious": {
				"noArrayIndexKey": "off",
				"noConsole": {
					"level": "warn",
					"options": {
						"allow": ["warn", "error", "info"]
					}
				}
			},
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "error"
			},
			"style": {
				"useNamingConvention": {
					"level": "warn",
					"options": {
						"strictCase": false,
						"requireAscii": true
					}
				}
			},
			"complexity": {
				"noExcessiveCognitiveComplexity": {
					"level": "warn",
					"options": {
						"maxAllowedComplexity": 25
					}
				}
			},
			"nursery": {
				"useSortedClasses": {
					"level": "warn",
					"fix": "safe",
					"options": {
						"functions": ["cn", "clsx", "cva"]
					}
				}
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded"
		}
	},
	"css": {
		"parser": {
			"cssModules": true,
			"tailwindDirectives": true
		},
		"linter": {
			"enabled": true
		},
		"formatter": {
			"enabled": true
		}
	},
	"json": {
		"formatter": {
			"enabled": true,
			"indentStyle": "tab"
		}
	},
	"overrides": [
		{
			"includes": [
				"apps/renderer/src/core/types/tools.ts",
				"apps/renderer/src/hooks/use-platform.ts",
				"apps/renderer/src/lib/hotkey-adapter.ts",
				"**/__tests__/**"
			],
			"linter": {
				"rules": {
					"style": {
						"useNamingConvention": "off"
					}
				}
			}
		},
		{
			"includes": ["**/vite.config.ts"],
			"linter": {
				"rules": {
					"style": {
						"useNamingConvention": "off"
					}
				}
			}
		}
	],
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							{
								"source": [":PACKAGE:", ":NODE:", "!@/**"],
								"type": true
							},
							[":PACKAGE:", ":NODE:", "!@/**"],
							":BLANK_LINE:",
							{
								"source": "@/**",
								"type": true
							},
							"@/**",
							":BLANK_LINE:",
							{
								"source": ":ALIAS:",
								"type": true
							},
							":ALIAS:",
							":BLANK_LINE:",
							{
								"source": ":PATH:",
								"type": true
							},
							":PATH:"
						]
					}
				}
			}
		}
	}
}
